# Docker image metadata
DOCKER_IMAGE_PREFIX=jewelcancy
IMAGE_TAG=latest

# Public domain and support
DOMAIN=www.jewelcancy.com
ROOT_DOMAIN=jewelcancy.com
SUPPORT_EMAIL=support@jewelcancy.com

# Public router ports
HTTP_PORT=80
HTTPS_PORT=443
FRONTEND_PORT=80

# Backend runtime
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb://mongodb:27017/jobplacements
MONGO_URL=mongodb://mongodb:27017/jobplacements
JWT_SECRET=change_this_to_a_random_64_character_secret_before_production
JWT_EXPIRE=7d
JWT_COOKIE_MAX_AGE_MS=
CLIENT_URL=https://www.jewelcancy.com
FRONTEND_URL=https://www.jewelcancy.com
PRODUCTION_URL=https://www.jewelcancy.com
ALLOWED_ORIGINS=https://www.jewelcancy.com,https://jewelcancy.com,http://localhost:5173
LEGACY_ALLOWED_ORIGINS=

# Upload limits
MAX_FILE_SIZE=26214400
CHAT_ATTACHMENT_MAX_SIZE=26214400
PROFILE_IMAGE_MAX_SIZE=10485760
COMPANY_LOGO_MAX_SIZE=10485760
BLOG_IMAGE_MAX_SIZE=26214400
RESUME_MAX_SIZE=26214400

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_USER=
EMAIL_PASS=

# Frontend build-time variables
VITE_API_URL=https://www.jewelcancy.com/api/v1
VITE_SOCKET_URL=https://www.jewelcancy.com
VITE_RAZORPAY_KEY_ID=
VITE_SUPPORT_EMAIL=support@jewelcancy.com
VITE_DEBUG_MODE=false

# API throttling
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Development overrides for docker-compose.dev.yml
DEV_FRONTEND_PORT=5173
DEV_BACKEND_PORT=5000
DEV_MONGODB_PORT=27017
MONGO_INITDB_ROOT_USERNAME=jobs_admin
MONGO_INITDB_ROOT_PASSWORD=changeThisMongoPassword
MONGO_INITDB_DATABASE=jobplacements
DEV_VITE_API_URL=http://localhost:5000/api/v1
DEV_VITE_SOCKET_URL=http://localhost:5000
DEV_VITE_DEBUG_MODE=true
DEV_CLIENT_URL=http://localhost:5173
DEV_FRONTEND_URL=http://localhost:5173
DEV_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80
