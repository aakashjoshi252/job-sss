# Docker image metadata
DOCKER_IMAGE_PREFIX=job-placements
IMAGE_TAG=latest

# Host ports
FRONTEND_PORT=80
BACKEND_PORT=5000
MONGODB_PORT=27017

# MongoDB container credentials
MONGO_INITDB_ROOT_USERNAME=jobs_admin
MONGO_INITDB_ROOT_PASSWORD=changeThisMongoPassword
MONGO_INITDB_DATABASE=jobplacements

# Backend runtime
NODE_ENV=production
PORT=5000
JWT_SECRET=change_this_to_a_random_64_character_secret_before_production
JWT_EXPIRE=7d
CLIENT_URL=http://localhost
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_replace_with_real_key
RAZORPAY_KEY_SECRET=replace_with_real_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_real_webhook_secret

# Frontend build-time variables
VITE_API_URL=/api/v1
VITE_SOCKET_URL=
VITE_RAZORPAY_KEY_ID=rzp_test_replace_with_real_key
VITE_DEBUG_MODE=false

# Development overrides
DEV_FRONTEND_PORT=5173
DEV_BACKEND_PORT=5000
DEV_MONGODB_PORT=27017
DEV_VITE_API_URL=http://localhost:5000
DEV_VITE_SOCKET_URL=http://localhost:5000
DEV_VITE_DEBUG_MODE=true
DEV_CLIENT_URL=http://localhost:5173
DEV_FRONTEND_URL=http://localhost:5173
DEV_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80
